{
  "manifest_version": 3,
  "name": "GrabIt",
  "version": "4.0.0",
  "description": "Download YouTube, Instagram, and any media — fast.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "tabs",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:7272/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "scripts/background/sw.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*", "https://www.youtube.com/*", "https://youtube.com/*", "https://youtu.be/*", "https://music.youtube.com/*"],
      "js": ["scripts/content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}